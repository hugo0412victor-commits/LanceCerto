# Local: use seu PostgreSQL local. Producao/Vercel: use um PostgreSQL online.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/autoarremate?schema=public"

# Necessario porque o schema Prisma usa directUrl.
# Em producao, prefira a URL direta/unpooled do provedor Postgres.
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/autoarremate?schema=public"

# Local: http://localhost:3000
# Producao: https://seu-dominio.vercel.app
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"

# Opcional. Preencha se alguma integracao futura precisar da URL publica.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

APP_DEMO_MODE="false"
STORAGE_DRIVER="local"
LOCAL_STORAGE_PATH="./public/uploads"
SYSTEM_NAME="AutoArremate Gestao"
COMPANY_NAME="Empresa Demo"

# Importacao de lote
LOT_IMPORT_FETCH_TIMEOUT_MS="20000"

# Use true apenas em ambiente local/self-hosted com Chrome ou Edge instalado.
# Na Vercel serverless esse fallback nao esta disponivel.
LOT_IMPORT_ENABLE_BROWSER_FALLBACK="false"
